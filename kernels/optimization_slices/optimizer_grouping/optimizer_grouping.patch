+class _DSQGWSourcewiseValueLaneAccum(torch.autograd.Function):
+    @staticmethod
+    def forward(
+        ctx,
+        x,
+        l3_states,
+        cand_token_indices,
+        cand_types,
+        cand_sources,
+        cand_mask,
+        n_types: int,
+        n_sources: int,
+        has_l3: bool,
+        eps: float,
+    ):
+        if not _TRITON_SOURCEWISE_AVAILABLE or triton is None or _dsqg_w_value_lane_accum_kernel is None:
+            raise NotImplementedError("DSQG-W sourcewise value-lane accumulation requires Triton")
+        bsz, seq_len, d = x.shape
+        j_count = cand_token_indices.shape[-1]
+        valid = cand_mask.to(dtype=torch.bool)
+        weights = valid.to(dtype=x.dtype)
+        type_mass = x.new_zeros((bsz, seq_len, int(n_types)))
+        source_mass = x.new_zeros((bsz, seq_len, int(n_sources)))
+        for slot_idx in range(j_count):
+            w_j = weights[:, :, slot_idx]
+            type_mass.scatter_add_(2, cand_types[:, :, slot_idx, None], w_j[:, :, None])
+            source_mass.scatter_add_(2, cand_sources[:, :, slot_idx, None], w_j[:, :, None])
+        mass = weights.sum(dim=-1)
+        all_sum = torch.empty((bsz, seq_len, d), device=x.device, dtype=x.dtype)
+        type_sum = torch.zeros((bsz, seq_len, int(n_types), d), device=x.device, dtype=x.dtype)
+        source_sum = torch.zeros((bsz, seq_len, int(n_sources), d), device=x.device, dtype=x.dtype)
+        block = 256
+        total = int(all_sum.numel())
+        l3_arg = l3_states if bool(has_l3) else x
+        _dsqg_w_value_lane_accum_kernel[(triton.cdiv(total, block),)](
+            x.contiguous(),
+            l3_arg.contiguous(),
+            cand_token_indices.contiguous(),
+            cand_types.contiguous(),
+            cand_sources.contiguous(),
+            valid.contiguous(),
+            all_sum,
+            type_sum,
+            source_sum,
+            total=total,
+            n=seq_len,
+            j_count=j_count,
+            d=d,
+            n_types=int(n_types),
+            n_sources=int(n_sources),
+            has_l3=bool(has_l3),
+            block=block,
+        )
+        all_read = torch.where(mass[:, :, None] > 0, all_sum / mass[:, :, None].clamp_min(float(eps)), torch.zeros_like(all_sum))
+        type_reads = torch.where(
+            type_mass[:, :, :, None] > 0,
+            type_sum / type_mass[:, :, :, None].clamp_min(float(eps)),
+            torch.zeros_like(type_sum),
+        )
+        source_reads = torch.where(
+            source_mass[:, :, :, None] > 0,
+            source_sum / source_mass[:, :, :, None].clamp_min(float(eps)),
+            torch.zeros_like(source_sum),
+        )
+        ctx.save_for_backward(cand_token_indices, cand_types, cand_sources, valid, mass, type_mass, source_mass)
+        ctx.x_shape = tuple(x.shape)
+        ctx.has_l3 = bool(has_l3)
+        ctx.n_types = int(n_types)
+        ctx.n_sources = int(n_sources)
+        ctx.eps = float(eps)
+        return all_read, type_reads, source_reads, mass, type_mass, source_mass
+
+    @staticmethod
+    def backward(ctx, grad_all_read, grad_type_reads, grad_source_reads, grad_mass, grad_type_mass, grad_source_mass):
+        cand_token_indices, cand_types, cand_sources, valid, mass, type_mass, source_mass = ctx.saved_tensors
+        bsz, seq_len, d = ctx.x_shape
+        j_count = cand_token_indices.shape[-1]
+        grad_x = torch.zeros((bsz, seq_len, d), device=grad_all_read.device, dtype=grad_all_read.dtype)
+        grad_l3 = torch.zeros_like(grad_x) if ctx.has_l3 else None
+        block = 256
+        total = int(bsz * seq_len * j_count * d)
+        grad_l3_arg = grad_l3 if grad_l3 is not None else grad_x
+        _dsqg_w_value_lane_accum_backward_kernel[(triton.cdiv(total, block),)](
+            grad_all_read.contiguous(),
+            grad_type_reads.contiguous(),
+            grad_source_reads.contiguous(),
+            cand_token_indices.contiguous(),
+            cand_types.contiguous(),
+            cand_sources.contiguous(),
+            valid.contiguous(),
+            mass.contiguous(),
+            type_mass.contiguous(),
+            source_mass.contiguous(),
+            grad_x,
+            grad_l3_arg,
+            total=total,
+            n=seq_len,
+            j_count=j_count,
+            d=d,
+            n_types=ctx.n_types,
+            n_sources=ctx.n_sources,
+            has_l3=ctx.has_l3,
+            eps=ctx.eps,
+            block=block,
+        )
+        return grad_x, grad_l3, None, None, None, None, None, None, None, None
+
