+#!/usr/bin/env python3
+"""Lean-W pivot throughput/memory/quality matrix runner.
+
+This script is intentionally parent-runnable and conservative: ``--dry-run`` only
+writes per-variant trainer configs plus a matrix summary, while ``--execute`` runs
+selected variants sequentially and parses any trainer logs it produces.  It does
+not perform long training by default; callers choose the bounded trainer sizes via
+CLI flags.
+"""
+from __future__ import annotations
+
+import argparse
+import json
+import math
+import os
+import re
+import statistics
+import subprocess
+import sys
+import time
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any
+
+ROOT = Path(__file__).resolve().parents[2]
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from scripts.run_dsqg_w_full_training import (  # noqa: E402
+    DEFAULT_DATASET,
+    DEFAULT_TOKENIZER,
+    build_run_config,
+    write_config,
+)
+
+DEFAULT_OUTPUT_DIR = Path("runs/dsqg_w_lean_w_pivot_matrix/matrix_runs")
+SUMMARY_JSON = "matrix_summary.json"
+SUMMARY_MD = "matrix_summary.md"
+RESULT_JSON = "matrix_result.json"
+
+STEP_RE = re.compile(
+    r"\[ep(?P<epoch>\d+)\s+step\s+(?P<step>\d+)/(?:\d+)\]\s+"
+    r"ce=(?P<ce>[-+0-9.eE]+).*?\s(?P<tok_s>[-+0-9.eE]+)\s+tok/s(?P<tail>.*)$"
+)
+BENCH_STEADY_RE = re.compile(r"steady_tok_s=(?P<tok_s>[-+0-9.eE]+)")
+PEAK_VRAM_RE = re.compile(r"peak_vram=(?P<vram>[-+0-9.eE]+)MB")
+VAL_PPL_RE = re.compile(r"Val PPL\s+(?P<ppl>[-+0-9.eE]+)")
+SUMMARY_PPL_RE = re.compile(r"ep(?P<epoch>\d+):\s+ppl=(?P<ppl>[-+0-9.eE]+)")
+KEYVAL_RE = re.compile(r"(?P<key>w_[A-Za-z0-9_]+|dsqg_w_[A-Za-z0-9_]+)=(?P<value>[-+0-9.eE]+)")
+
+
+@dataclass(frozen=True)
+class MatrixVariant:
+    """One Lean-W matrix row."""
+
+    name: str
+    purpose: str
+    overrides: dict[str, Any]
+    env_overrides: dict[str, str] = field(default_factory=dict)
+    mainline: bool = True
+    deprecated: bool = False
+    execute_by_default: bool = True
+    notes: tuple[str, ...] = ()
+
+
+def matrix_variants() -> list[MatrixVariant]:
+    """Return the fixed Lean-W pivot matrix rows.
+
+    The mainline Lean-W rows use open forced lateral gates
+    (``DWARF_DSQG_W_FORCE_WIDTH_GATE=1`` and
+    ``DWARF_DSQG_W_FORCE_TYPED_MIXER_GATE=1``) and leave the DSQG-W output
+    writeback gate learned/cautious via ``gate_init``.
+    """
+
+    lean_w_open_lateral: dict[str, Any] = {
+        "dsqg_w": True,
+        "sourcewise": True,
+        "triton_sourcewise": True,
+        "width_cell": True,
+        "typed_mixer": True,
+        "evidence_binding_hub": False,
+        "force_width_gate": 1.0,
+        "force_typed_mixer_gate": 1.0,
+        "gate_init": -5.0,
+        "width_gate_init": -2.5,
+        "typed_mixer_gate_init": -2.5,
+        "max_candidates": 16,
+        "k_question": 4,
+        "k_hisa_evidence": 4,
+        "k_l3_skip": 2,
+        "local_offsets": "none",
+        "long_offsets": "none",
+        "pre_hisa_ema": True,
+    }
+    return [
+        MatrixVariant(
+            name="control_no_w",
+            purpose="Matched DSR/HISA no-W control for quality and baseline throughput/VRAM.",
+            overrides={
+                "dsqg_w": False,
+                "sites": "final",
+                "sourcewise": False,
+                "triton_sourcewise": False,
+                "width_cell": False,
+                "typed_mixer": False,
+                "evidence_binding_hub": False,
+                "max_candidates": 16,
+                "k_question": 4,
+                "k_hisa_evidence": 4,
+                "k_l3_skip": 2,
+                "pre_hisa_ema": True,
+            },
+        ),
+        MatrixVariant(
+            name="lean_w_6_final_open_lateral_output_learned",
+            purpose="Mainline Lean-W at layer 6 and final site; no EBH; lateral gates forced open; output gate learned.",
+            overrides={**lean_w_open_lateral, "sites": "6,final"},
+            notes=("Primary Lean-W candidate after dropping W@L3.",),
+        ),
+        MatrixVariant(
+            name="lean_w_final_open_lateral_output_learned",
+            purpose="Single-site final Lean-W; no EBH; isolates whether L6 W is worth its cost.",
+            overrides={**lean_w_open_lateral, "sites": "final"},
+        ),
+        MatrixVariant(
+            name="lean_w_6_final_candidate_prior",
+            purpose="Lean-W 6,final plus cheap scalar candidate/evidence prior as EBH substitute.",
+            overrides={
+                **lean_w_open_lateral,
+                "sites": "6,final",
+                "evidence_prior": True,
+                "evidence_prior_clip": 2.0,
+                "evidence_prior_init_scale": 0.0,
+            },
+            notes=("Prior is zero-init/no-op at start; telemetry should show nonzero only after learning.",),
+        ),
+        MatrixVariant(
+            name="lean_w_reduced_candidates_j8_q2_hisa2_l3_1",
+            purpose="Reduced-candidate Lean-W row to measure whether simpler J improves throughput/VRAM without quality loss.",
+            overrides={
+                **lean_w_open_lateral,
+                "sites": "6,final",
+                "max_candidates": 8,
+                "k_question": 2,
+                "k_hisa_evidence": 2,
+                "k_l3_skip": 1,
+            },
+            notes=("If this wins mechanically, test l3=0 as the next parent-owned micro-matrix row.",),
+        ),
+        MatrixVariant(
+            name="deprecated_ebh_fused_historical_reference",
+            purpose="Deprecated/non-mainline EBH fused-packet historical reference only; not a promotion path.",
+            overrides={
+                "dsqg_w": True,
+                "sites": "2,6,final",
+                "sourcewise": True,
+                "triton_sourcewise": True,
+                "width_cell": False,
+                "typed_mixer": False,
+                "evidence_binding_hub": True,
+                "ebh_sourcewise_packet": True,
+                "ebh_fused_lane_accum": True,
+                "ebh_score_features": True,
+                "gate_init": -2.5,
+                "ebh_gate_init": -5.0,
+                "max_candidates": 16,
+                "k_question": 4,
+                "k_hisa_evidence": 4,
+                "k_l3_skip": 2,
+                "local_offsets": "none",
+                "long_offsets": "none",
+                "pre_hisa_ema": True,
+            },
+            mainline=False,
+            deprecated=True,
+            execute_by_default=False,
+            notes=("Included only to compare against previous EBH fused evidence; skip unless parent explicitly asks.",),
+        ),
+    ]
+
+
+def _json_safe(value: Any) -> Any:
+    if isinstance(value, Path):
+        return str(value)
+    if isinstance(value, dict):
+        return {str(k): _json_safe(v) for k, v in value.items()}
+    if isinstance(value, (list, tuple)):
+        return [_json_safe(v) for v in value]
+    return value
+
+
+def _float_or_none(raw: str | None) -> float | None:
+    if raw is None:
+        return None
+    try:
+        value = float(raw)
+    except (TypeError, ValueError):
+        return None
+    return value if math.isfinite(value) else None
+
+
+def parse_training_log(*paths: Path) -> dict[str, Any]:
+    """Parse trainer stdout/stderr for throughput, memory, quality, and W telemetry."""
+
+    step_tok_s: list[float] = []
+    ce_values: list[float] = []
+    w_history: dict[str, list[float]] = {}
+    steady_tok_s: float | None = None
+    peak_vram_mb: float | None = None
+    final_ppl: float | None = None
+    final_ce: float | None = None
+    parsed_lines = 0
+
+    for path in paths:
+        if not path.exists():
+            continue
+        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
+            parsed_lines += 1
+            if bench := BENCH_STEADY_RE.search(line):
+                steady_tok_s = _float_or_none(bench.group("tok_s")) or steady_tok_s
+            if vram := PEAK_VRAM_RE.search(line):
+                peak_vram_mb = _float_or_none(vram.group("vram")) or peak_vram_mb
+            if ppl := VAL_PPL_RE.search(line):
+                final_ppl = _float_or_none(ppl.group("ppl")) or final_ppl
+            if ppl := SUMMARY_PPL_RE.search(line):
+                final_ppl = _float_or_none(ppl.group("ppl")) or final_ppl
+            if step := STEP_RE.search(line):
+                tok_s = _float_or_none(step.group("tok_s"))
+                ce = _float_or_none(step.group("ce"))
+                if tok_s is not None:
+                    step_tok_s.append(tok_s)
+                if ce is not None:
+                    ce_values.append(ce)
+                    final_ce = ce
+                for match in KEYVAL_RE.finditer(step.group("tail")):
+                    value = _float_or_none(match.group("value"))
+                    if value is not None:
+                        w_history.setdefault(match.group("key"), []).append(value)
+
+    if steady_tok_s is None and step_tok_s:
+        tail = step_tok_s[-min(5, len(step_tok_s)):]
+        steady_tok_s = statistics.fmean(tail)
+    key_w_telemetry = {
+        key: {
+            "last": values[-1],
+            "mean_tail": statistics.fmean(values[-min(5, len(values)):]),
+            "count": len(values),
+        }
+        for key, values in sorted(w_history.items())
+        if values
+    }
+    return {
+        "parsed_lines": parsed_lines,
+        "steady_tok_s": steady_tok_s,
+        "peak_vram_mb": peak_vram_mb,
+        "final_ce": final_ce,
+        "final_ppl": final_ppl,
+        "step_tok_s_count": len(step_tok_s),
+        "key_w_telemetry": key_w_telemetry,
+    }
+
+
+def build_variant_config(args: argparse.Namespace, variant: MatrixVariant) -> dict[str, Any]:
+    variant_dir = args.output_dir / variant.name
+    common: dict[str, Any] = {
+        "output_dir": variant_dir,
+        "run_name": variant.name,
+        "gpu": args.gpu,
+        "max_acc_steps": args.max_acc_steps,
+        "train_seqs": args.train_seqs,
+        "val_seqs": args.val_seqs,
+        "batch_size": args.batch_size,
+        "grad_accum": args.grad_accum,
+        "epochs": args.epochs,
+        "log_interval": args.log_interval,
+        "passkey_trials": args.passkey_trials,
+        "seq_len": args.seq_len,
+        "dataset": args.dataset,
+        "tokenizer": args.tokenizer,
+        "python": args.python,
+        "lr": args.lr,
+        "min_lr_ratio": args.min_lr_ratio,
+        "lr_warmup_steps": args.lr_warmup_steps,
+        "hisa_top_m": args.hisa_top_m,
+    }
+    # build_run_config accepts None for the optional scalar controls, but not for
+    # plain int/path defaults except where specified above.
+    config = build_run_config(**common, **variant.overrides)
+    env = config["env"]
+    env.update(variant.env_overrides)
+    if args.bench_only:
+        env["DWARF_BENCH_ONLY"] = "1"
+    if args.fast_telemetry:
+        env["DWARF_DSQG_W_FAST_TELEMETRY"] = "1"
+    if args.profile_dsqg_w:
+        env["DWARF_PROFILE_DSQG_W"] = "1"
+    config["matrix_variant"] = {
+        "name": variant.name,
+        "purpose": variant.purpose,
+        "mainline": variant.mainline,
+        "deprecated": variant.deprecated,
+        "execute_by_default": variant.execute_by_default,
+        "notes": list(variant.notes),
+    }
+    return config
+
+
+def _selected_variants(args: argparse.Namespace) -> list[MatrixVariant]:
+    variants = matrix_variants()
+    if args.only:
+        requested = {part.strip() for part in args.only.split(",") if part.strip()}
+        known = {variant.name for variant in variants}
+        unknown = sorted(requested - known)
+        if unknown:
+            raise SystemExit(f"unknown --only variant(s): {', '.join(unknown)}; known={', '.join(sorted(known))}")
+        variants = [variant for variant in variants if variant.name in requested]
+    if args.execute and not args.include_deprecated:
+        variants = [variant for variant in variants if not variant.deprecated and variant.execute_by_default]
+    return variants
+
+
+def execute_config(config: dict[str, Any], *, timeout_s: int | None = None) -> dict[str, Any]:
+    write_config(config)
+    env = os.environ.copy()
+    env.update(config["env"])
+    stdout_path = Path(config["stdout_path"])
+    stderr_path = Path(config["stderr_path"])
+    stdout_path.parent.mkdir(parents=True, exist_ok=True)
+    t0 = time.time()
+    with stdout_path.open("w", encoding="utf-8") as stdout, stderr_path.open("w", encoding="utf-8") as stderr:
+        try:
+            completed = subprocess.run(
+                config["command"],
+                cwd=ROOT,
+                env=env,
+                stdout=stdout,
+                stderr=stderr,
+                text=True,
+                check=False,
+                timeout=timeout_s,
+            )
+            returncode = int(completed.returncode)
+            timed_out = False
+        except subprocess.TimeoutExpired:
+            returncode = 124
+            timed_out = True
+    elapsed_s = time.time() - t0
+    parsed = parse_training_log(stdout_path, stderr_path)
+    result = {
+        "returncode": returncode,
+        "timed_out": timed_out,
+        "elapsed_s": elapsed_s,
+        "stdout_path": str(stdout_path),
+        "stderr_path": str(stderr_path),
+        "parsed": parsed,
+    }
+    result_path = Path(config["output_dir"]) / RESULT_JSON
+    result_path.write_text(json.dumps(_json_safe(result), indent=2, sort_keys=True) + "\n", encoding="utf-8")
+    result["result_path"] = str(result_path)
+    return result
+
+
+def write_summary(output_dir: Path, rows: list[dict[str, Any]]) -> tuple[Path, Path]:
+    output_dir.mkdir(parents=True, exist_ok=True)
+    summary_json = output_dir / SUMMARY_JSON
+    summary_md = output_dir / SUMMARY_MD
+    payload = {
+        "objective": "lean_w_pivot_throughput_memory_quality_matrix",
+        "row_count": len(rows),
+        "rows": rows,
+    }
+    summary_json.write_text(json.dumps(_json_safe(payload), indent=2, sort_keys=True) + "\n", encoding="utf-8")
+
+    md_lines = [
+        "# Lean-W Pivot Matrix Summary",
+        "",
+        "| variant | mainline | deprecated | config | steady tok/s | peak VRAM MB | final CE | final PPL | purpose |",
+        "|---|---:|---:|---|---:|---:|---:|---:|---|",
+    ]
+    for row in rows:
+        parsed = row.get("parsed") or {}
+        md_lines.append(
+            "| {name} | {mainline} | {deprecated} | `{config}` | {tok_s} | {vram} | {ce} | {ppl} | {purpose} |".format(
+                name=row["name"],
+                mainline=int(bool(row["mainline"])),
+                deprecated=int(bool(row["deprecated"])),
+                config=row["config_path"],
+                tok_s=_fmt_metric(parsed.get("steady_tok_s")),
+                vram=_fmt_metric(parsed.get("peak_vram_mb")),
+                ce=_fmt_metric(parsed.get("final_ce")),
+                ppl=_fmt_metric(parsed.get("final_ppl")),
+                purpose=str(row["purpose"]).replace("|", "/"),
+            )
+        )
+    md_lines.extend(
+        [
+            "",
+            "Dry-run configs are safe to inspect before parent-owned execution.",
+            "Deprecated EBH rows are historical references only and are skipped by default under `--execute`.",
+        ]
+    )
+    summary_md.write_text("\n".join(md_lines) + "\n", encoding="utf-8")
+    return summary_json, summary_md
+
+
+def _fmt_metric(value: Any) -> str:
+    if value is None:
+        return ""
+    if isinstance(value, (int, float)) and math.isfinite(float(value)):
+        return f"{float(value):.4g}"
+    return str(value)
+
+
+def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description="Lean-W pivot throughput/memory/quality matrix runner")
+    mode = parser.add_mutually_exclusive_group(required=True)
+    mode.add_argument("--dry-run", action="store_true", help="Write per-variant configs and summaries; do not execute trainer.")
+    mode.add_argument("--execute", action="store_true", help="Run selected variants sequentially and parse logs.")
+    parser.add_argument("--output-dir", type=Path, default=DEFAULT_OUTPUT_DIR)
+    parser.add_argument("--only", default="", help="Comma-separated variant names to dry-run/execute.")
+    parser.add_argument("--include-deprecated", action="store_true", help="Include deprecated EBH reference rows during --execute.")
+    parser.add_argument("--gpu", default="0")
+    parser.add_argument("--max-acc-steps", type=int, default=25)
+    parser.add_argument("--train-seqs", type=int, default=256)
+    parser.add_argument("--val-seqs", type=int, default=128)
+    parser.add_argument("--batch-size", type=int, default=1)
+    parser.add_argument("--grad-accum", type=int, default=1)
+    parser.add_argument("--epochs", type=int, default=1)
+    parser.add_argument("--log-interval", type=int, default=1)
+    parser.add_argument("--passkey-trials", type=int, default=2)
+    parser.add_argument("--seq-len", type=int, default=None)
+    parser.add_argument("--hisa-top-m", type=int, default=None)
+    parser.add_argument("--lr", type=float, default=None)
+    parser.add_argument("--min-lr-ratio", type=float, default=None)
+    parser.add_argument("--lr-warmup-steps", type=int, default=None)
+    parser.add_argument("--dataset", type=Path, default=DEFAULT_DATASET)
+    parser.add_argument("--tokenizer", type=Path, default=DEFAULT_TOKENIZER)
+    parser.add_argument("--python", type=Path, default=Path(sys.executable))
+    parser.add_argument("--bench-only", action="store_true", help="Set DWARF_BENCH_ONLY=1 for execute runs.")
+    parser.add_argument("--fast-telemetry", action="store_true", help="Set DWARF_DSQG_W_FAST_TELEMETRY=1 to reduce telemetry overhead.")
+    parser.add_argument("--profile-dsqg-w", action="store_true", help="Set DWARF_PROFILE_DSQG_W=1.")
+    parser.add_argument("--timeout-s", type=int, default=None, help="Optional per-variant execute timeout.")
+    return parser.parse_args(argv)
+
+
+def main(argv: list[str] | None = None) -> dict[str, Any]:
+    args = parse_args(argv)
+    args.output_dir = Path(args.output_dir)
+    if not args.output_dir.is_absolute():
+        args.output_dir = ROOT / args.output_dir
+    variants = _selected_variants(args)
+    rows: list[dict[str, Any]] = []
+    overall_pass = True
+
+    for variant in variants:
+        config = build_variant_config(args, variant)
+        config_path = write_config(config)
+        row: dict[str, Any] = {
+            "name": variant.name,
+            "purpose": variant.purpose,
+            "mainline": variant.mainline,
+            "deprecated": variant.deprecated,
+            "execute_by_default": variant.execute_by_default,
+            "config_path": str(config_path),
+            "output_dir": config["output_dir"],
+            "command": config["command"],
+            "env_subset": {
+                key: config["env"].get(key, "")
+                for key in sorted(config["env"])
+                if key.startswith("DWARF_DSQG_W") or key in {"DWARF_PRE_HISA_EMA", "DWARF_BENCH_ONLY"}
+            },
+            "manifest": config.get("manifest", {}),
+            "executed": False,
+            "parsed": {},
+        }
+        if args.execute:
+            exec_result = execute_config(config, timeout_s=args.timeout_s)
+            row.update(exec_result)
+            row["executed"] = True
+            row["parsed"] = exec_result.get("parsed", {})
+            if exec_result["returncode"] != 0:
+                overall_pass = False
+        rows.append(row)
+
+    summary_json, summary_md = write_summary(args.output_dir, rows)
+    result = {
+        "pass": overall_pass,
+        "mode": "execute" if args.execute else "dry-run",
+        "output_dir": str(args.output_dir),
+        "summary_json": str(summary_json),
+        "summary_md": str(summary_md),
+        "variant_count": len(rows),
+        "variants": [row["name"] for row in rows],
+        "rows": rows,
+    }
+    print(json.dumps(_json_safe(result), indent=2, sort_keys=True))
+    return result
+
+
+if __name__ == "__main__":
+    result = main()
+    raise SystemExit(0 if result["pass"] else 2)
